{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/refresh-scores.ts": {
      "memory": 256,
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/refresh-scores", "destination": "/api/refresh-scores" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/refresh-scores",
      "schedule": "*/3 * * * *"
    }
  ]
}
